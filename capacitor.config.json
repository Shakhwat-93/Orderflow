{
  "appId": "com.orderflow.premium",
  "appName": "OrderFlow",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "showSpinner": false,
      "backgroundColor": "#0f172a"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#f4f6fb",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
